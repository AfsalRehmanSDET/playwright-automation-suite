{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "strict": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": [
        "pages/**/*.ts",
        "tests/**/*.ts",
        "utils/**/*.ts",
        "fixtures/**/*.ts",
        "playwright.config.js",
        "types/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "test-results",
        "playwright-report"
    ]
}